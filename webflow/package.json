{
  "name": "book-3d-webflow",
  "version": "0.1.0",
  "private": true,
  "description": "Webflow code component wrapper around the 3D book renderer",
  "main": "src/Book3D.tsx",
  "scripts": {
    "bundle": "webflow library bundle --public-path http://localhost:8080",
    "bundle:dev": "webflow library bundle --public-path http://localhost:8080 --dev",
    "share": "webflow library share",
    "serve": "http-server ./dist -p 8080 --cors"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.164.0"
  },
  "devDependencies": {
    "@webflow/react": "latest",
    "@webflow/webflow-cli": "latest",
    "@webflow/data-types": "latest",
    "@types/react": "^18.2.0",
    "@types/three": "^0.164.0",
    "typescript": "^5.0.0",
    "http-server": "^14.1.1"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
